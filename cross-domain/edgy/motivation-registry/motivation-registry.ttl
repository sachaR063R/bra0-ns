# =============================================================================
# § 8. Outcomes (edgy:Outcome / archimate:Outcome)
# =============================================================================

bra0mot:Outcome-PortableEvidencePack a edgy:Outcome , archimate:Outcome ;
    rdfs:label "Evidence packs portable across substrates"@en ;
    skos:prefLabel "Portable Evidence Pack"@en ;
    skos:definition "Measurable end-state where any bra0 evidence pack — shapes, instances, provenance — can be exported, audited, and re-imported on any W3C-conformant substrate without loss."@en ;
    rdfs:comment "Measurable end-state: any bra0 evidence pack (shapes + instances + provenance) can be exported, audited, and re-imported on any W3C-conformant substrate without loss."@en ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

bra0mot:Outcome-LowEnergyKnowledgeOps a edgy:Outcome , archimate:Outcome ;
    rdfs:label "Low-energy knowledge operations"@en ;
    skos:prefLabel "Low-energy KS Ops"@en ;
    skos:definition "Measurable end-state where bra0 knowledge operations execute under a published energy budget per operation, with no build-time pre-baking inflating redeploy cost."@en ;
    rdfs:comment "Measurable end-state: bra0 knowledge operations (validation, query, reactive shape) execute under a published energy budget per operation, with no build-time pre-baking that would inflate redeploy cost."@en ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

bra0mot:Outcome-AlternativesAvailable a edgy:Outcome , archimate:Outcome ;
    rdfs:label "Alternatives available at every critical dependency"@en ;
    skos:prefLabel "Alternatives Available"@en ;
    skos:definition "Measurable end-state where every critical dependency of a bra0 deployment has at least one viable, documented, and reachable alternative — exit path testable on demand."@en ;
    rdfs:comment "Measurable end-state: for every critical dependency in a bra0 deployment (substrate, validator, runtime, vendor, ontology), at least one viable, documented, and reachable alternative is preserved — exit path testable on demand. Operationalises the Hirschman Exit option."@en ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

bra0mot:Outcome-LiveSchemaMutation a edgy:Outcome , archimate:Outcome ;
    rdfs:label "Live schema mutation in production"@en ;
    skos:prefLabel "Live Schema Mutation"@en ;
    skos:definition "Measurable end-state where shapes and instances mutate in production without redeploy or build-time intervention."@en ;
    rdfs:comment "Measurable end-state: shapes, ShEx schemas, SHACL constraints, and bra0 instances mutate in running production with no redeploy and no build-time pre-baking. Operationalises the time-dimension of Continuity."@en ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

bra0mot:Outcome-ClaimsTraceableToProvenance a edgy:Outcome , archimate:Outcome ;
    rdfs:label "Claims traceable to provenance end-to-end"@en ;
    skos:prefLabel "Claims Traceable"@en ;
    skos:definition "Measurable end-state where every claim — decision, shape, audit, AI output, agent action — carries an auditable PROV-O chain reconstructible end-to-end."@en ;
    rdfs:comment "Measurable end-state: every claim emitted within bra0 — decision, shape acceptance, audit conclusion, AI output, agent action — carries a PROV-O chain such that any auditor can reconstruct the derivation end-to-end with no post-hoc explanation gap."@en ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

# =============================================================================
# § 9. Stories (edgy:Story / archimate:CourseOfAction)
# =============================================================================
#
# Stories are courses of action — the "moyen" (means) by which Purposes (the
# "fin"/end) are pursued. Discriminator (motivation-registry-style-guide.md
# § 4 critère 11): a Story names a HOW; a Purpose names a WHY/WHAT-FOR.
#
# Each Story dual-types as edgy:Story (EDGY identity-facet narrative) and
# archimate:CourseOfAction (ArchiMate strategy element). Linkage to served
# Purposes uses both edgy:contextualizes (EDGY canonical) and
# archimate:realizes (ArchiMate canonical) to make the punning operational.
# =============================================================================

bra0mot:Story-SymbolicFirstPrimacy a edgy:Story , archimate:CourseOfAction ;
    rdfs:label "Symbolic-First Primacy"@en ;
    skos:prefLabel "Symbolic-First Primacy"@en ;
    skos:definition "Course of action that resolves bra0 capability invocations through symbolic engines (rudof, SHACL, SPARQL) before any neural fallback, materialising the Symbolic-First Cascade (ADR-027 sophia + candle)."@en ;
    rdfs:comment "Symbolic-first execution policy: every capability invocation tries the symbolic path (rudof shacl-validate, SPARQL query, ShEx schema check) first ; the neural runtime (sophia + candle) is engaged only when the symbolic path is structurally inapplicable. Materialises P1 Least Power at runtime and serves Frugality (cheap symbolic operations) and EvidenceFirst (auditable derivation chain) without becoming a Purpose itself — it is the 'how', not the 'why'."@en ;
    skos:scopeNote "This is a means, not an end. Purposes served: Frugality (symbolic ops are orders of magnitude cheaper than neural inference) and EvidenceFirst (symbolic outputs carry deterministic provenance). If a future course of action serves the same Purposes more frugally or with stronger evidence guarantees, it supersedes this one without disturbing the Purposes themselves."@en ;
    edgy:contextualizes bra0mot:Purpose-Frugality , bra0mot:Purpose-EvidenceFirst ;
    archimate:realizes bra0mot:Purpose-Frugality , bra0mot:Purpose-EvidenceFirst ;
    edgy:viewedThrough edgy:identityFacet ;
    dcterms:source <https://github.com/sachaR063R/bra0/blob/main/_bmad/docs/adr/ADR-027-symbolic-first-cascade.md> ;
    dcterms:creator bra0mot:Stakeholder-Sacha .

bra0mot:Story-OpenCoreCollaboration a edgy:Story , archimate:CourseOfAction ;
    rdfs:label "Open-Core Collaboration"@en ;
    skos:prefLabel "Open-Core Collaboration"@en ;
    skos:definition "Course of action that ships the bra0 core under MIT OR Apache-2.0 and ships enterprise modules as separate proprietary repositories interfacing through stable hooks, following the GitLab open-core licensing pattern."@en ;
    rdfs:comment "Open-core distribution policy: bra0 core (KS Studio, ontologies, agent contracts, validation pipeline) is permissively licensed (MIT OR Apache-2.0) and forkable ; enterprise plugins (audit packs, vendor-specific connectors) live in separate repositories with proprietary licenses and connect through stable, documented hook interfaces. Materialises Sovereignty (every dependency forkable) and ContinuousInteroperability (hook contracts published as part of core) without becoming a Purpose itself."@en ;
    skos:scopeNote "This is a means, not an end. Purposes served: Sovereignty (permissive license preserves Exit option) and ContinuousInteroperability (hook contracts are first-class interfaces). If a future licensing or distribution arrangement serves the same Purposes more robustly, it supersedes this one without disturbing the Purposes themselves."@en ;
    edgy:contextualizes bra0mot:Purpose-Sovereignty , bra0mot:Purpose-ContinuousInteroperability ;
    archimate:realizes bra0mot:Purpose-Sovereignty , bra0mot:Purpose-ContinuousInteroperability ;
    edgy:viewedThrough edgy:identityFacet ;
    dcterms:creator bra0mot:Stakeholder-Sacha .
