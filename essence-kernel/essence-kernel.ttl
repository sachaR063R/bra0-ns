ess:UnderstandTheRequirements a ess:ActivitySpace ;
  rdfs:label "Understand the Requirements"@en ;
  ess:belongsToArea ess:SolutionArea ;
  ess:predecessorOf ess:ShapeTheSystem ;
  rdfs:comment "Establish a shared understanding of what the system to be produced must do."@en .

ess:ShapeTheSystem a ess:ActivitySpace ;
  rdfs:label "Shape the System"@en ;
  ess:belongsToArea ess:SolutionArea ;
  ess:predecessorOf ess:ImplementTheSystem ;
  rdfs:comment "Shape the system so that it is easy to develop, change, and maintain."@en .

ess:ImplementTheSystem a ess:ActivitySpace ;
